{
  "name": "tia-connect-vscode",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.4.0",
  "publisher": "FEELAUTOM",
  "license": "MIT",
  "icon": "resources/icons/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "TIA Portal",
    "Siemens",
    "PLC",
    "SCL",
    "STL",
    "automation",
    "industrial"
  ],
  "activationEvents": [
    "onView:tiaProjectExplorer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "tiaConnect.serverUrl": {
          "type": "string",
          "default": "http://localhost:9000",
          "description": "%config.serverUrl.description%"
        },
        "tiaConnect.apiKey": {
          "type": "string",
          "default": "",
          "description": "%config.apiKey.description%"
        },
        "tiaConnect.autoReimportOnSave": {
          "type": "boolean",
          "default": true,
          "description": "%config.autoReimportOnSave.description%"
        },
        "tiaConnect.autoCompileOnReimport": {
          "type": "boolean",
          "default": false,
          "description": "%config.autoCompileOnReimport.description%"
        },
        "tiaConnect.autoSaveInterval": {
          "type": "number",
          "default": 5,
          "enum": [
            0,
            5,
            10,
            15
          ],
          "enumDescriptions": [
            "%config.autoSaveInterval.disabled%",
            "%config.autoSaveInterval.5min%",
            "%config.autoSaveInterval.10min%",
            "%config.autoSaveInterval.15min%"
          ],
          "description": "%config.autoSaveInterval.description%"
        },
        "tiaConnect.excludeFromReimport": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%config.excludeFromReimport.description%"
        },
        "tiaConnect.executablePath": {
          "type": "string",
          "default": "C:\\Program Files\\FeelAutomCorp\\TiaConnect\\TiaPortalApi.App.exe",
          "description": "%config.executablePath.description%"
        }
      }
    },
    "commands": [
      {
        "command": "tiaConnect.connect",
        "title": "%command.connect%",
        "category": "T-IA Connect",
        "icon": "$(plug)"
      },
      {
        "command": "tiaConnect.disconnect",
        "title": "%command.disconnect%",
        "category": "T-IA Connect",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "tiaConnect.refreshProject",
        "title": "%command.refreshProject%",
        "category": "T-IA Connect",
        "icon": "$(refresh)"
      },
      {
        "command": "tiaConnect.openBlock",
        "title": "%command.openBlock%",
        "category": "T-IA Connect",
        "icon": "$(go-to-file)"
      },
      {
        "command": "tiaConnect.compileDevice",
        "title": "%command.compileDevice%",
        "category": "T-IA Connect",
        "icon": "$(gear)"
      },
      {
        "command": "tiaConnect.compileBlock",
        "title": "%command.compileBlock%",
        "category": "T-IA Connect",
        "icon": "$(check)"
      },
      {
        "command": "tiaConnect.exportBlock",
        "title": "%command.exportBlock%",
        "category": "T-IA Connect",
        "icon": "$(desktop-download)"
      },
      {
        "command": "tiaConnect.vcsCommit",
        "title": "%command.vcsCommit%",
        "category": "T-IA Connect VCS",
        "icon": "$(check)"
      },
      {
        "command": "tiaConnect.vcsRefresh",
        "title": "%command.vcsRefresh%",
        "category": "T-IA Connect VCS",
        "icon": "$(refresh)"
      },
      {
        "command": "tiaConnect.vcsInit",
        "title": "%command.vcsInit%",
        "category": "T-IA Connect VCS",
        "icon": "$(repo)"
      },
      {
        "command": "tiaConnect.vcsPush",
        "title": "%command.vcsPush%",
        "category": "T-IA Connect VCS",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "tiaConnect.vcsPull",
        "title": "%command.vcsPull%",
        "category": "T-IA Connect VCS",
        "icon": "$(cloud-download)"
      },
      {
        "command": "tiaConnect.vcsRemote",
        "title": "%command.vcsRemote%",
        "category": "T-IA Connect VCS",
        "icon": "$(remote)"
      },
      {
        "command": "tiaConnect.vcsBranch",
        "title": "%command.vcsBranch%",
        "category": "T-IA Connect VCS",
        "icon": "$(git-branch)"
      },
      {
        "command": "tiaConnect.vcsLog",
        "title": "%command.vcsLog%",
        "category": "T-IA Connect VCS",
        "icon": "$(history)"
      },
      {
        "command": "tiaConnect.testRefresh",
        "title": "%command.testRefresh%",
        "category": "T-IA Connect Tests",
        "icon": "$(refresh)"
      },
      {
        "command": "tiaConnect.testRunAll",
        "title": "%command.testRunAll%",
        "category": "T-IA Connect Tests",
        "icon": "$(run-all)"
      },
      {
        "command": "tiaConnect.testRunSingle",
        "title": "%command.testRunSingle%",
        "category": "T-IA Connect Tests",
        "icon": "$(play)"
      },
      {
        "command": "tiaConnect.testShowResult",
        "title": "%command.testShowResult%",
        "category": "T-IA Connect Tests",
        "icon": "$(open-preview)"
      },
      {
        "command": "tiaConnect.pipelineList",
        "title": "%command.pipelineList%",
        "category": "T-IA Connect Pipelines",
        "icon": "$(list-flat)"
      },
      {
        "command": "tiaConnect.pipelineRun",
        "title": "%command.pipelineRun%",
        "category": "T-IA Connect Pipelines",
        "icon": "$(play)"
      },
      {
        "command": "tiaConnect.pipelineHistory",
        "title": "%command.pipelineHistory%",
        "category": "T-IA Connect Pipelines",
        "icon": "$(history)"
      },
      {
        "command": "tiaConnect.pipelineFromTemplate",
        "title": "%command.pipelineFromTemplate%",
        "category": "T-IA Connect Pipelines",
        "icon": "$(file-add)"
      },
      {
        "command": "tiaConnect.showCrossReferences",
        "title": "%command.showCrossReferences%",
        "category": "T-IA Connect",
        "icon": "$(references)"
      },
      {
        "command": "tiaConnect.openTagTable",
        "title": "%command.openTagTable%",
        "category": "T-IA Connect",
        "icon": "$(table)"
      },
      {
        "command": "tiaConnect.openUdt",
        "title": "%command.openUdt%",
        "category": "T-IA Connect",
        "icon": "$(symbol-struct)"
      },
      {
        "command": "tiaConnect.importSourceFile",
        "title": "%command.importSourceFile%",
        "category": "T-IA Connect",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "tiaConnect.createBlock",
        "title": "%command.createBlock%",
        "category": "T-IA Connect",
        "icon": "$(file-add)"
      },
      {
        "command": "tiaConnect.switchProject",
        "title": "%command.switchProject%",
        "category": "T-IA Connect",
        "icon": "$(folder-opened)"
      },
      {
        "command": "tiaConnect.openSettings",
        "title": "%command.openSettings%",
        "category": "T-IA Connect",
        "icon": "$(settings-gear)"
      },
      {
        "command": "tiaConnect.vcsTreeRefresh",
        "title": "%command.vcsTreeRefresh%",
        "category": "T-IA Connect VCS",
        "icon": "$(refresh)"
      },
      {
        "command": "tiaConnect.vcsExportPreview",
        "title": "%command.vcsExportPreview%",
        "category": "T-IA Connect VCS",
        "icon": "$(eye)"
      },
      {
        "command": "tiaConnect.vcsTreeInit",
        "title": "%command.vcsTreeInit%",
        "category": "T-IA Connect VCS",
        "icon": "$(repo)"
      },
      {
        "command": "tiaConnect.vcsTreeCommit",
        "title": "%command.vcsTreeCommit%",
        "category": "T-IA Connect VCS",
        "icon": "$(check)"
      },
      {
        "command": "tiaConnect.vcsDiffFile",
        "title": "%command.vcsDiffFile%",
        "category": "T-IA Connect VCS",
        "icon": "$(diff)"
      },
      {
        "command": "tiaConnect.launchHeadless",
        "title": "%command.launchHeadless%",
        "category": "T-IA Connect",
        "icon": "$(terminal)"
      },
      {
        "command": "tiaConnect.launchGui",
        "title": "%command.launchGui%",
        "category": "T-IA Connect",
        "icon": "$(window)"
      },
      {
        "command": "tiaConnect.login",
        "title": "%command.login%",
        "category": "T-IA Connect",
        "icon": "$(sign-in)"
      },
      {
        "command": "tiaConnect.register",
        "title": "%command.register%",
        "category": "T-IA Connect",
        "icon": "$(person-add)"
      },
      {
        "command": "tiaConnect.logout",
        "title": "%command.logout%",
        "category": "T-IA Connect",
        "icon": "$(sign-out)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tiaConnect",
          "title": "T-IA Connect",
          "icon": "resources/icons/tia-portal.svg"
        }
      ]
    },
    "views": {
      "tiaConnect": [
        {
          "id": "tiaProjectExplorer",
          "name": "%view.projectExplorer%"
        },
        {
          "id": "tiaVcsExplorer",
          "name": "%view.vcsExplorer%",
          "when": "tiaConnect.connected"
        },
        {
          "id": "tiaTestExplorer",
          "name": "%view.testExplorer%",
          "when": "tiaConnect.connected"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "tiaProjectExplorer",
        "contents": "%welcome.notAuthenticated%",
        "when": "!tiaConnect.authenticated"
      },
      {
        "view": "tiaProjectExplorer",
        "contents": "%welcome.serverNotInstalled%",
        "when": "tiaConnect.authenticated && tiaConnect.serverNotInstalled"
      },
      {
        "view": "tiaProjectExplorer",
        "contents": "%welcome.serverNotRunning%",
        "when": "tiaConnect.authenticated && tiaConnect.serverNotRunning && !tiaConnect.serverNotInstalled"
      },
      {
        "view": "tiaProjectExplorer",
        "contents": "%welcome.notConnected%",
        "when": "tiaConnect.authenticated && !tiaConnect.connected && !tiaConnect.serverNotRunning"
      },
      {
        "view": "tiaProjectExplorer",
        "contents": "%welcome.noProject%",
        "when": "tiaConnect.connected"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tiaConnect.vcsExportPreview",
          "when": "view == tiaVcsExplorer",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.vcsTreeCommit",
          "when": "view == tiaVcsExplorer",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.vcsTreeRefresh",
          "when": "view == tiaVcsExplorer",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.testRunAll",
          "when": "view == tiaTestExplorer",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.testRefresh",
          "when": "view == tiaTestExplorer",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.connect",
          "when": "view == tiaProjectExplorer && !tiaConnect.connected",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.disconnect",
          "when": "view == tiaProjectExplorer && tiaConnect.connected",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.switchProject",
          "when": "view == tiaProjectExplorer && tiaConnect.connected",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.refreshProject",
          "when": "view == tiaProjectExplorer && tiaConnect.connected",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.openSettings",
          "when": "view == tiaProjectExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "tiaConnect.openBlock",
          "when": "view == tiaProjectExplorer && viewItem =~ /^block-(scl|stl)$/",
          "group": "inline"
        },
        {
          "command": "tiaConnect.compileDevice",
          "when": "view == tiaProjectExplorer && viewItem == device",
          "group": "1_compile"
        },
        {
          "command": "tiaConnect.createBlock",
          "when": "view == tiaProjectExplorer && viewItem == device",
          "group": "0_create"
        },
        {
          "command": "tiaConnect.importSourceFile",
          "when": "view == tiaProjectExplorer && viewItem == device",
          "group": "2_export"
        },
        {
          "command": "tiaConnect.compileBlock",
          "when": "view == tiaProjectExplorer && viewItem =~ /^block-/",
          "group": "1_compile"
        },
        {
          "command": "tiaConnect.exportBlock",
          "when": "view == tiaProjectExplorer && viewItem =~ /^block-(scl|stl)$/",
          "group": "2_export"
        },
        {
          "command": "tiaConnect.showCrossReferences",
          "when": "view == tiaProjectExplorer && viewItem =~ /^block-/",
          "group": "2_export"
        },
        {
          "command": "tiaConnect.vcsInit",
          "when": "view == tiaProjectExplorer && viewItem == project && !tiaConnect.vcsInitialized",
          "group": "3_vcs"
        },
        {
          "command": "tiaConnect.vcsCommit",
          "when": "view == tiaProjectExplorer && viewItem == project && tiaConnect.vcsInitialized",
          "group": "3_vcs"
        },
        {
          "command": "tiaConnect.vcsLog",
          "when": "view == tiaProjectExplorer && viewItem == project && tiaConnect.vcsInitialized",
          "group": "3_vcs"
        },
        {
          "command": "tiaConnect.vcsBranch",
          "when": "view == tiaProjectExplorer && viewItem == project && tiaConnect.vcsInitialized",
          "group": "3_vcs"
        },
        {
          "command": "tiaConnect.vcsRemote",
          "when": "view == tiaProjectExplorer && viewItem == project && tiaConnect.vcsInitialized",
          "group": "4_vcs_sync"
        },
        {
          "command": "tiaConnect.vcsPush",
          "when": "view == tiaProjectExplorer && viewItem == project && tiaConnect.vcsInitialized && tiaConnect.vcsHasRemote",
          "group": "4_vcs_sync"
        },
        {
          "command": "tiaConnect.vcsPull",
          "when": "view == tiaProjectExplorer && viewItem == project && tiaConnect.vcsInitialized && tiaConnect.vcsHasRemote",
          "group": "4_vcs_sync"
        },
        {
          "command": "tiaConnect.testRunSingle",
          "when": "view == tiaTestExplorer && viewItem == plcTest",
          "group": "inline"
        }
      ]
    },
    "languages": [
      {
        "id": "scl",
        "aliases": [
          "SCL",
          "Structured Control Language"
        ],
        "extensions": [
          ".scl"
        ],
        "configuration": "./language-configuration/scl-language-configuration.json"
      },
      {
        "id": "stl",
        "aliases": [
          "STL",
          "Statement List"
        ],
        "extensions": [
          ".stl"
        ],
        "configuration": "./language-configuration/stl-language-configuration.json"
      }
    ],
    "snippets": [
      {
        "language": "scl",
        "path": "./snippets/scl.json"
      }
    ],
    "keybindings": [
      {
        "command": "tiaConnect.compileDevice",
        "key": "ctrl+shift+b",
        "when": "tiaConnect.connected"
      }
    ],
    "grammars": [
      {
        "language": "scl",
        "scopeName": "source.scl",
        "path": "./syntaxes/scl.tmLanguage.json"
      },
      {
        "language": "stl",
        "scopeName": "source.stl",
        "path": "./syntaxes/stl.tmLanguage.json"
      }
    ]
  },
  "extensionDependencies": [],
  "capabilities": {
    "uriHandler": true
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "l10n": "./l10n",
  "repository": {
    "type": "git",
    "url": "https://github.com/feelautomcorp/tia-connect-vscode"
  }
}
