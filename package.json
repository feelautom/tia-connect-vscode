    "viewsContainers": {
      "activitybar": [
        {
          "id": "tiaConnect",
          "title": "T-IA Connect",
          "icon": "resources/icons/tia-portal.svg"
        }
      ],
      "panel": [
        {
          "id": "tiaCopilot",
          "title": "T-IA Copilot",
          "icon": "resources/icons/copilot-chat.svg"
        }
      ]
    },
    "views": {
      "tiaConnect": [
        {
          "id": "tiaProjectExplorer",
          "name": "%view.projectExplorer%"
        },
        {
          "id": "tiaVcsExplorer",
          "name": "%view.vcsExplorer%",
          "when": "tiaConnect.connected"
        },
        {
          "id": "tiaTestExplorer",
          "name": "%view.testExplorer%",
          "when": "tiaConnect.connected"
        }
      ],
      "tiaCopilot": [
        {
          "id": "tiaCopilotChat",
          "name": "%view.copilotChat%",
          "type": "webview"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "tiaProjectExplorer",
        "contents": "%welcome.notAuthenticated%",
        "when": "!tiaConnect.authenticated"
      },
      {
        "view": "tiaProjectExplorer",
        "contents": "%welcome.serverNotInstalled%",
        "when": "tiaConnect.authenticated && tiaConnect.serverNotInstalled"
      },
      {
        "view": "tiaProjectExplorer",
        "contents": "%welcome.serverNotRunning%",
        "when": "tiaConnect.authenticated && tiaConnect.serverNotRunning && !tiaConnect.serverNotInstalled"
      },
      {
        "view": "tiaProjectExplorer",
        "contents": "%welcome.notConnected%",
        "when": "tiaConnect.authenticated && !tiaConnect.connected && !tiaConnect.serverNotRunning"
      },
      {
        "view": "tiaProjectExplorer",
        "contents": "%welcome.noProject%",
        "when": "tiaConnect.authenticated && tiaConnect.connected"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tiaConnect.vcsExportPreview",
          "when": "view == tiaVcsExplorer",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.vcsTreeCommit",
          "when": "view == tiaVcsExplorer",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.vcsTreeRefresh",
          "when": "view == tiaVcsExplorer",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.testRunAll",
          "when": "view == tiaTestExplorer",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.testRefresh",
          "when": "view == tiaTestExplorer",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.copilotClear",
          "when": "view == tiaCopilotChat",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.logout",
          "when": "view == tiaProjectExplorer && tiaConnect.authenticated",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.connect",
          "when": "view == tiaProjectExplorer && !tiaConnect.connected",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.disconnect",
          "when": "view == tiaProjectExplorer && tiaConnect.connected",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.switchProject",
          "when": "view == tiaProjectExplorer && tiaConnect.connected",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.refreshProject",
          "when": "view == tiaProjectExplorer && tiaConnect.connected",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.openSettings",
          "when": "view == tiaProjectExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "tiaConnect.openBlock",
          "when": "view == tiaProjectExplorer && viewItem =~ /^block-(scl|stl)$/",
          "group": "inline"
        },
        {
          "command": "tiaConnect.compileDevice",
          "when": "view == tiaProjectExplorer && viewItem == device",
          "group": "1_compile"
        },
        {
          "command": "tiaConnect.createBlock",
          "when": "view == tiaProjectExplorer && viewItem == device",
          "group": "0_create"
        },
        {
          "command": "tiaConnect.importSourceFile",
          "when": "view == tiaProjectExplorer && viewItem == device",
          "group": "2_export"
        },
        {
          "command": "tiaConnect.compileBlock",
          "when": "view == tiaProjectExplorer && viewItem =~ /^block-/",
          "group": "1_compile"
        },
        {
          "command": "tiaConnect.exportBlock",
          "when": "view == tiaProjectExplorer && viewItem =~ /^block-(scl|stl)$/",
          "group": "2_export"
        },
        {
          "command": "tiaConnect.showCrossReferences",
          "when": "view == tiaProjectExplorer && viewItem =~ /^block-/",
          "group": "2_export"
        },
        {
          "command": "tiaConnect.exportAll",
          "when": "view == tiaProjectExplorer && viewItem == device",
          "group": "2_export"
        },
        {
          "command": "tiaConnect.detectOrphans",
          "when": "view == tiaProjectExplorer && viewItem == device",
          "group": "2_export"
        },
        {
          "command": "tiaConnect.exportHmiAll",
          "when": "view == tiaProjectExplorer && viewItem == device",
          "group": "3_hmi"
        },
        {
          "command": "tiaConnect.importHmiAll",
          "when": "view == tiaProjectExplorer && viewItem == device",
          "group": "3_hmi"
        },
        {
          "command": "tiaConnect.exportHwConfig",
          "when": "view == tiaProjectExplorer && viewItem == device",
          "group": "4_hardware"
        },
        {
          "command": "tiaConnect.importHwConfig",
          "when": "view == tiaProjectExplorer && viewItem == device",
          "group": "4_hardware"
        },
        {
          "command": "tiaConnect.exportTagsCsv",
          "when": "view == tiaProjectExplorer && viewItem == tagTable",
          "group": "1_export"
        },
        {
          "command": "tiaConnect.exportTagsXlsx",
          "when": "view == tiaProjectExplorer && viewItem == tagTable",
          "group": "1_export"
        },
        {
          "command": "tiaConnect.exportTagsXml",
          "when": "view == tiaProjectExplorer && viewItem == tagTable",
          "group": "1_export"
        },
        {
          "command": "tiaConnect.importTagsCsv",
          "when": "view == tiaProjectExplorer && viewItem == tagTable",
          "group": "2_import"
        },
        {
          "command": "tiaConnect.importTagsXlsx",
          "when": "view == tiaProjectExplorer && viewItem == tagTable",
          "group": "2_import"
        },
        {
          "command": "tiaConnect.exportUdt",
          "when": "view == tiaProjectExplorer && viewItem == udt",
          "group": "1_export"
        },
        {
          "command": "tiaConnect.importUdt",
          "when": "view == tiaProjectExplorer && viewItem =~ /^section-udts$/",
          "group": "2_import"
        },
        {
          "command": "tiaConnect.exportWatchTable",
          "when": "view == tiaProjectExplorer && viewItem == watchTable",
          "group": "1_export"
        },
        {
          "command": "tiaConnect.vcsInit",
          "when": "view == tiaProjectExplorer && viewItem == project && !tiaConnect.vcsInitialized",
          "group": "3_vcs"
        },
        {
          "command": "tiaConnect.vcsCommit",
          "when": "view == tiaProjectExplorer && viewItem == project && tiaConnect.vcsInitialized",
          "group": "3_vcs"
        },
        {
          "command": "tiaConnect.vcsLog",
          "when": "view == tiaProjectExplorer && viewItem == project && tiaConnect.vcsInitialized",
          "group": "3_vcs"
        },
        {
          "command": "tiaConnect.vcsBranch",
          "when": "view == tiaProjectExplorer && viewItem == project && tiaConnect.vcsInitialized",
          "group": "3_vcs"
        },
        {
          "command": "tiaConnect.vcsRemote",
          "when": "view == tiaProjectExplorer && viewItem == project && tiaConnect.vcsInitialized",
          "group": "4_vcs_sync"
        },
        {
          "command": "tiaConnect.vcsPush",
          "when": "view == tiaProjectExplorer && viewItem == project && tiaConnect.vcsInitialized && tiaConnect.vcsHasRemote",
          "group": "4_vcs_sync"
        },
        {
          "command": "tiaConnect.vcsPull",
          "when": "view == tiaProjectExplorer && viewItem == project && tiaConnect.vcsInitialized && tiaConnect.vcsHasRemote",
          "group": "4_vcs_sync"
        },
        {
          "command": "tiaConnect.testRunSingle",
          "when": "view == tiaTestExplorer && viewItem == plcTest",
          "group": "inline"
        }
      ]
    },
    "languages": [
      {
        "id": "scl",
        "aliases": [
          "SCL",
          "Structured Control Language"
        ],
        "extensions": [
          ".scl"
        ],
        "configuration": "./language-configuration/scl-language-configuration.json"
      },
      {
        "id": "stl",
        "aliases": [
          "STL",
          "Statement List"
        ],
        "extensions": [
          ".stl"
        ],
        "configuration": "./language-configuration/stl-language-configuration.json"
      }
    ],
    "snippets": [
      {
        "language": "scl",
        "path": "./snippets/scl.json"
      }
    ],
    "keybindings": [
      {
        "command": "tiaConnect.compileDevice",
        "key": "ctrl+shift+b",
        "when": "tiaConnect.connected"
      }
    ],
    "grammars": [
      {
        "language": "scl",
        "scopeName": "source.scl",
        "path": "./syntaxes/scl.tmLanguage.json"
      },
      {
        "language": "stl",
        "scopeName": "source.stl",
        "path": "./syntaxes/stl.tmLanguage.json"
      }
    ]
  },
