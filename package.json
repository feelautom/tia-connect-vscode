{
  "name": "tia-connect-vscode",
  "displayName": "T-IA Connect for VS Code",
  "description": "Explore, edit SCL/STL, and compile Siemens TIA Portal projects from VS Code via T-IA Connect REST API",
  "version": "0.2.2",
  "publisher": "FEELAUTOM",
  "license": "MIT",
  "icon": "resources/icons/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "TIA Portal",
    "Siemens",
    "PLC",
    "SCL",
    "STL",
    "automation",
    "industrial"
  ],
  "activationEvents": [
    "onView:tiaProjectExplorer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "T-IA Connect",
      "properties": {
        "tiaConnect.serverUrl": {
          "type": "string",
          "default": "http://localhost:9000",
          "description": "T-IA Connect server URL"
        },
        "tiaConnect.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for authentication (X-API-Key header)"
        },
        "tiaConnect.autoReimportOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically reimport SCL/STL blocks into TIA Portal on save"
        },
        "tiaConnect.autoCompileOnReimport": {
          "type": "boolean",
          "default": false,
          "description": "Automatically compile after reimporting a block"
        },
        "tiaConnect.autoSaveInterval": {
          "type": "number",
          "default": 5,
          "enum": [
            0,
            5,
            10,
            15
          ],
          "enumDescriptions": [
            "Disabled",
            "Every 5 minutes",
            "Every 10 minutes",
            "Every 15 minutes"
          ],
          "description": "Auto-save interval for open block files (in minutes). This is a safety backup — reimport to TIA only happens on manual Ctrl+S."
        },
        "tiaConnect.executablePath": {
          "type": "string",
          "default": "C:\\Program Files\\FeelAutomCorp\\TiaConnect\\TiaPortalApi.App.exe",
          "description": "Path to the T-IA Connect server executable. Used to launch the server when it is not running."
        }
      }
    },
    "commands": [
      {
        "command": "tiaConnect.connect",
        "title": "Connect to Server",
        "category": "T-IA Connect",
        "icon": "$(plug)"
      },
      {
        "command": "tiaConnect.disconnect",
        "title": "Disconnect from Server",
        "category": "T-IA Connect",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "tiaConnect.refreshProject",
        "title": "Refresh Project Tree",
        "category": "T-IA Connect",
        "icon": "$(refresh)"
      },
      {
        "command": "tiaConnect.openBlock",
        "title": "Open Block",
        "category": "T-IA Connect",
        "icon": "$(go-to-file)"
      },
      {
        "command": "tiaConnect.compileDevice",
        "title": "Compile Device",
        "category": "T-IA Connect",
        "icon": "$(gear)"
      },
      {
        "command": "tiaConnect.compileBlock",
        "title": "Compile Block",
        "category": "T-IA Connect",
        "icon": "$(check)"
      },
      {
        "command": "tiaConnect.exportBlock",
        "title": "Export Block to File",
        "category": "T-IA Connect",
        "icon": "$(desktop-download)"
      },
      {
        "command": "tiaConnect.vcsCommit",
        "title": "Commit",
        "category": "T-IA Connect VCS",
        "icon": "$(check)"
      },
      {
        "command": "tiaConnect.vcsRefresh",
        "title": "Refresh VCS Status",
        "category": "T-IA Connect VCS",
        "icon": "$(refresh)"
      },
      {
        "command": "tiaConnect.vcsInit",
        "title": "Initialize VCS Repository",
        "category": "T-IA Connect VCS",
        "icon": "$(repo)"
      },
      {
        "command": "tiaConnect.vcsPush",
        "title": "Push",
        "category": "T-IA Connect VCS",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "tiaConnect.vcsPull",
        "title": "Pull",
        "category": "T-IA Connect VCS",
        "icon": "$(cloud-download)"
      },
      {
        "command": "tiaConnect.vcsRemote",
        "title": "Configure Remote",
        "category": "T-IA Connect VCS",
        "icon": "$(remote)"
      },
      {
        "command": "tiaConnect.vcsBranch",
        "title": "Branch Operations",
        "category": "T-IA Connect VCS",
        "icon": "$(git-branch)"
      },
      {
        "command": "tiaConnect.vcsLog",
        "title": "Show Commit Log",
        "category": "T-IA Connect VCS",
        "icon": "$(history)"
      },
      {
        "command": "tiaConnect.testRefresh",
        "title": "Refresh PLC Tests",
        "category": "T-IA Connect Tests",
        "icon": "$(refresh)"
      },
      {
        "command": "tiaConnect.testRunAll",
        "title": "Run All PLC Tests",
        "category": "T-IA Connect Tests",
        "icon": "$(run-all)"
      },
      {
        "command": "tiaConnect.testRunSingle",
        "title": "Run Test",
        "category": "T-IA Connect Tests",
        "icon": "$(play)"
      },
      {
        "command": "tiaConnect.testShowResult",
        "title": "Show Test Results",
        "category": "T-IA Connect Tests",
        "icon": "$(open-preview)"
      },
      {
        "command": "tiaConnect.pipelineList",
        "title": "List Pipelines",
        "category": "T-IA Connect Pipelines",
        "icon": "$(list-flat)"
      },
      {
        "command": "tiaConnect.pipelineRun",
        "title": "Run Pipeline",
        "category": "T-IA Connect Pipelines",
        "icon": "$(play)"
      },
      {
        "command": "tiaConnect.pipelineHistory",
        "title": "Pipeline History",
        "category": "T-IA Connect Pipelines",
        "icon": "$(history)"
      },
      {
        "command": "tiaConnect.pipelineFromTemplate",
        "title": "Create Pipeline from Template",
        "category": "T-IA Connect Pipelines",
        "icon": "$(file-add)"
      },
      {
        "command": "tiaConnect.showCrossReferences",
        "title": "Show Cross-References",
        "category": "T-IA Connect",
        "icon": "$(references)"
      },
      {
        "command": "tiaConnect.openTagTable",
        "title": "Open Tag Table",
        "category": "T-IA Connect",
        "icon": "$(table)"
      },
      {
        "command": "tiaConnect.openUdt",
        "title": "Open UDT",
        "category": "T-IA Connect",
        "icon": "$(symbol-struct)"
      },
      {
        "command": "tiaConnect.importSourceFile",
        "title": "Import SCL/STL File",
        "category": "T-IA Connect",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "tiaConnect.switchProject",
        "title": "Switch Project",
        "category": "T-IA Connect",
        "icon": "$(folder-opened)"
      },
      {
        "command": "tiaConnect.openSettings",
        "title": "Settings",
        "category": "T-IA Connect",
        "icon": "$(settings-gear)"
      },
      {
        "command": "tiaConnect.vcsTreeRefresh",
        "title": "Refresh",
        "category": "T-IA Connect VCS",
        "icon": "$(refresh)"
      },
      {
        "command": "tiaConnect.vcsExportPreview",
        "title": "Export Preview (detect changes)",
        "category": "T-IA Connect VCS",
        "icon": "$(eye)"
      },
      {
        "command": "tiaConnect.vcsTreeInit",
        "title": "Initialize VCS",
        "category": "T-IA Connect VCS",
        "icon": "$(repo)"
      },
      {
        "command": "tiaConnect.vcsTreeCommit",
        "title": "Commit Changes",
        "category": "T-IA Connect VCS",
        "icon": "$(check)"
      },
      {
        "command": "tiaConnect.vcsDiffFile",
        "title": "Show Changes",
        "category": "T-IA Connect VCS",
        "icon": "$(diff)"
      },
      {
        "command": "tiaConnect.launchHeadless",
        "title": "Launch Server (Headless)",
        "category": "T-IA Connect",
        "icon": "$(terminal)"
      },
      {
        "command": "tiaConnect.launchGui",
        "title": "Launch Server (GUI)",
        "category": "T-IA Connect",
        "icon": "$(window)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tiaConnect",
          "title": "T-IA Connect",
          "icon": "resources/icons/tia-portal.svg"
        }
      ]
    },
    "views": {
      "tiaConnect": [
        {
          "id": "tiaProjectExplorer",
          "name": "Project Explorer"
        },
        {
          "id": "tiaVcsExplorer",
          "name": "Source Control",
          "when": "tiaConnect.connected"
        },
        {
          "id": "tiaTestExplorer",
          "name": "PLC Tests",
          "when": "tiaConnect.connected"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "tiaProjectExplorer",
        "contents": "T-IA Connect server is not running.\n\nLaunch the server and connect automatically:\n[Launch Headless](command:tiaConnect.launchHeadless)\n[Launch with GUI](command:tiaConnect.launchGui)\n\nOr connect to an already running server:\n[Connect to Server](command:tiaConnect.connect)\n[Open Settings](command:workbench.action.openSettings?%22tiaConnect%22)",
        "when": "tiaConnect.serverNotRunning"
      },
      {
        "view": "tiaProjectExplorer",
        "contents": "No connection to T-IA Connect server.\n\nMake sure the T-IA Connect server is running, then click Connect.\n[Connect to Server](command:tiaConnect.connect)\n\nYou can configure the server URL and API key in the extension settings.\n[Open Settings](command:workbench.action.openSettings?%22tiaConnect%22)",
        "when": "!tiaConnect.connected && !tiaConnect.serverNotRunning"
      },
      {
        "view": "tiaProjectExplorer",
        "contents": "Connected but no project found.\n\nOpen a TIA Portal project in T-IA Connect, then refresh.\n[Refresh](command:tiaConnect.refreshProject)",
        "when": "tiaConnect.connected"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tiaConnect.vcsExportPreview",
          "when": "view == tiaVcsExplorer",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.vcsTreeCommit",
          "when": "view == tiaVcsExplorer",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.vcsTreeRefresh",
          "when": "view == tiaVcsExplorer",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.testRunAll",
          "when": "view == tiaTestExplorer",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.testRefresh",
          "when": "view == tiaTestExplorer",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.connect",
          "when": "view == tiaProjectExplorer && !tiaConnect.connected",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.disconnect",
          "when": "view == tiaProjectExplorer && tiaConnect.connected",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.switchProject",
          "when": "view == tiaProjectExplorer && tiaConnect.connected",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.refreshProject",
          "when": "view == tiaProjectExplorer && tiaConnect.connected",
          "group": "navigation"
        },
        {
          "command": "tiaConnect.openSettings",
          "when": "view == tiaProjectExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "tiaConnect.openBlock",
          "when": "view == tiaProjectExplorer && viewItem =~ /^block-(scl|stl)$/",
          "group": "inline"
        },
        {
          "command": "tiaConnect.compileDevice",
          "when": "view == tiaProjectExplorer && viewItem == device",
          "group": "1_compile"
        },
        {
          "command": "tiaConnect.importSourceFile",
          "when": "view == tiaProjectExplorer && viewItem == device",
          "group": "2_export"
        },
        {
          "command": "tiaConnect.compileBlock",
          "when": "view == tiaProjectExplorer && viewItem =~ /^block-/",
          "group": "1_compile"
        },
        {
          "command": "tiaConnect.exportBlock",
          "when": "view == tiaProjectExplorer && viewItem =~ /^block-(scl|stl)$/",
          "group": "2_export"
        },
        {
          "command": "tiaConnect.showCrossReferences",
          "when": "view == tiaProjectExplorer && viewItem =~ /^block-/",
          "group": "2_export"
        },
        {
          "command": "tiaConnect.vcsInit",
          "when": "view == tiaProjectExplorer && viewItem == project && !tiaConnect.vcsInitialized",
          "group": "3_vcs"
        },
        {
          "command": "tiaConnect.vcsCommit",
          "when": "view == tiaProjectExplorer && viewItem == project && tiaConnect.vcsInitialized",
          "group": "3_vcs"
        },
        {
          "command": "tiaConnect.vcsLog",
          "when": "view == tiaProjectExplorer && viewItem == project && tiaConnect.vcsInitialized",
          "group": "3_vcs"
        },
        {
          "command": "tiaConnect.vcsBranch",
          "when": "view == tiaProjectExplorer && viewItem == project && tiaConnect.vcsInitialized",
          "group": "3_vcs"
        },
        {
          "command": "tiaConnect.vcsRemote",
          "when": "view == tiaProjectExplorer && viewItem == project && tiaConnect.vcsInitialized",
          "group": "4_vcs_sync"
        },
        {
          "command": "tiaConnect.vcsPush",
          "when": "view == tiaProjectExplorer && viewItem == project && tiaConnect.vcsInitialized && tiaConnect.vcsHasRemote",
          "group": "4_vcs_sync"
        },
        {
          "command": "tiaConnect.vcsPull",
          "when": "view == tiaProjectExplorer && viewItem == project && tiaConnect.vcsInitialized && tiaConnect.vcsHasRemote",
          "group": "4_vcs_sync"
        },
        {
          "command": "tiaConnect.testRunSingle",
          "when": "view == tiaTestExplorer && viewItem == plcTest",
          "group": "inline"
        }
      ]
    },
    "languages": [
      {
        "id": "scl",
        "aliases": [
          "SCL",
          "Structured Control Language"
        ],
        "extensions": [
          ".scl"
        ],
        "configuration": "./language-configuration/scl-language-configuration.json"
      },
      {
        "id": "stl",
        "aliases": [
          "STL",
          "Statement List"
        ],
        "extensions": [
          ".stl"
        ],
        "configuration": "./language-configuration/stl-language-configuration.json"
      }
    ],
    "snippets": [
      {
        "language": "scl",
        "path": "./snippets/scl.json"
      }
    ],
    "keybindings": [
      {
        "command": "tiaConnect.compileDevice",
        "key": "ctrl+shift+b",
        "when": "tiaConnect.connected"
      }
    ],
    "grammars": [
      {
        "language": "scl",
        "scopeName": "source.scl",
        "path": "./syntaxes/scl.tmLanguage.json"
      },
      {
        "language": "stl",
        "scopeName": "source.stl",
        "path": "./syntaxes/stl.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/feelautomcorp/tia-connect-vscode"
  }
}
