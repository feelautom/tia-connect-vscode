      },
      {
        "command": "tiaConnect.exportUdt",
        "title": "Export UDT (XML)",
        "category": "T-IA Connect"
      },
      {
        "command": "tiaConnect.importUdt",
        "title": "Import UDT (XML)",
        "category": "T-IA Connect"
      },
      {
        "command": "tiaConnect.exportWatchTable",
        "title": "Export Watch Table (XML)",
        "category": "T-IA Connect"
      },
      {
        "command": "tiaConnect.exportAll",
        "title": "%command.exportAll%",
        "category": "T-IA Connect",
        "icon": "$(cloud-download)"
      },
      {
        "command": "tiaConnect.detectOrphans",
        "title": "%command.detectOrphans%",
        "category": "T-IA Connect",
        "icon": "$(search-remove)"
      },
      {
        "command": "tiaConnect.exportHmiScreen",
        "title": "%command.exportHmiScreen%",
        "category": "T-IA Connect",
        "icon": "$(export)"
      },
      {
        "command": "tiaConnect.importHmiScreen",
        "title": "%command.importHmiScreen%",
        "category": "T-IA Connect",
        "icon": "$(import)"
      },
      {
