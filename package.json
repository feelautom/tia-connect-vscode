{
  "name": "tia-connect-vscode",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "1.0.0",
  "publisher": "FEELAUTOM",
  "license": "Elastic-2.0",
  "icon": "resources/icons/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "TIA Portal",
    "Siemens",
    "PLC",
    "SCL",
    "STL",
    "automation",
    "industrial"
  ],
  "activationEvents": [
    "onView:tiaProjectExplorer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "tiaConnect.serverUrl": {
          "type": "string",
          "default": "http://localhost:9000",
          "description": "%config.serverUrl.description%"
        },
        "tiaConnect.apiKey": {
          "type": "string",
          "default": "",
          "description": "%config.apiKey.description%"
        },
        "tiaConnect.autoReimportOnSave": {
          "type": "boolean",
          "default": true,
          "description": "%config.autoReimportOnSave.description%"
        },
        "tiaConnect.autoCompileOnReimport": {
          "type": "boolean",
          "default": false,
          "description": "%config.autoCompileOnReimport.description%"
        },
        "tiaConnect.autoSaveInterval": {
          "type": "number",
          "default": 5,
          "enum": [
            0,
            5,
            10,
            15
          ],
          "enumDescriptions": [
            "%config.autoSaveInterval.disabled%",
            "%config.autoSaveInterval.5min%",
            "%config.autoSaveInterval.10min%",
            "%config.autoSaveInterval.15min%"
          ],
          "description": "%config.autoSaveInterval.description%"
        },
        "tiaConnect.excludeFromReimport": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%config.excludeFromReimport.description%"
        },
        "tiaConnect.executablePath": {
          "type": "string",
          "default": "C:\\Program Files\\FeelAutomCorp\\TiaConnect\\TiaPortalApi.App.exe",
          "description": "%config.executablePath.description%"
        },
        "tiaConnect.autoConfigureMcp": {
          "type": "boolean",
          "default": true,
          "description": "%config.autoConfigureMcp.description%"
        }
      }
    },
    "chatParticipants": [
      {
        "id": "tia.connect",
        "name": "tia",
        "fullName": "T-IA Connect",
        "description": "TIA Portal automation assistant — create, edit, compile, test and deploy PLC programs",
        "isSticky": true
      }
    ],
    "languageModelTools": [
      {
        "name": "tia_get_project_overview",
        "displayName": "Get Project Overview",
        "modelDescription": "Get the current TIA Portal project overview including name, path, and list of devices",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "tia_list_devices",
        "displayName": "List Devices",
        "modelDescription": "List all devices (PLCs, HMIs) in the current TIA Portal project",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "tia_save_project",
        "displayName": "Save Project",
        "modelDescription": "Save the current TIA Portal project",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "tia_list_blocks",
        "displayName": "List Blocks",
        "modelDescription": "List all program blocks (OB, FB, FC, DB) for a TIA Portal PLC device. Returns block tree with names, types, numbers and programming languages.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "device": {
              "type": "string",
              "description": "Device name (e.g. PLC_1)"
            }
          },
          "required": [
            "device"
          ]
        }
      },
      {
        "name": "tia_get_block_content",
        "displayName": "Get Block Content",
        "modelDescription": "Get full block content including interface, networks, raw XML and source text for a specific block",
        "inputSchema": {
          "type": "object",
          "properties": {
            "device": {
              "type": "string",
              "description": "Device name"
            },
            "block": {
              "type": "string",
              "description": "Block name (e.g. Main, FB_Motor)"
            }
          },
          "required": [
            "device",
            "block"
          ]
        }
      },
      {
        "name": "tia_get_block_source",
        "displayName": "Get Block Source",
        "modelDescription": "Get the SCL or STL source code text of a block via GenerateSource. Use this to read editable code.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "device": {
              "type": "string",
              "description": "Device name"
            },
            "block": {
              "type": "string",
              "description": "Block name"
            }
          },
          "required": [
            "device",
            "block"
          ]
        }
      },
      {
        "name": "tia_create_block",
        "displayName": "Create Block",
        "modelDescription": "Create a new program block (FB, FC, OB, DB) in TIA Portal. Specify blockType, name and language.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "device": {
              "type": "string",
              "description": "Device name"
            },
            "blockType": {
              "type": "string",
              "enum": [
                "FB",
                "FC",
                "OB",
                "DB"
              ],
              "description": "Block type"
            },
            "name": {
              "type": "string",
              "description": "Block name (e.g. FB_Motor)"
            },
            "language": {
              "type": "string",
              "enum": [
                "SCL",
                "LAD",
                "FBD",
                "STL",
                "GRAPH"
              ],
              "description": "Programming language"
            }
          },
          "required": [
            "device",
            "blockType",
            "name",
            "language"
          ]
        }
      },
      {
        "name": "tia_import_scl",
        "displayName": "Import SCL Source",
        "modelDescription": "Import SCL source code into TIA Portal. The source is compiled as an external source. Include full SCL with FUNCTION/FUNCTION_BLOCK/DATA_BLOCK headers.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "device": {
              "type": "string",
              "description": "Device name"
            },
            "sclContent": {
              "type": "string",
              "description": "Full SCL source code including headers"
            },
            "sourceName": {
              "type": "string",
              "description": "Optional source file name"
            }
          },
          "required": [
            "device",
            "sclContent"
          ]
        }
      },
      {
        "name": "tia_export_block",
        "displayName": "Export Block",
        "modelDescription": "Export a block from TIA Portal as XML or other format",
        "inputSchema": {
          "type": "object",
          "properties": {
            "device": {
              "type": "string",
              "description": "Device name"
            },
            "block": {
              "type": "string",
              "description": "Block name"
            },
            "format": {
              "type": "string",
              "description": "Export format (xml, scl)"
            }
          },
          "required": [
            "device",
            "block"
          ]
        }
      },
      {
        "name": "tia_delete_block",
        "displayName": "Delete Block",
        "modelDescription": "Delete a program block from TIA Portal",
        "inputSchema": {
          "type": "object",
          "properties": {
            "device": {
              "type": "string",
              "description": "Device name"
            },
            "block": {
              "type": "string",
              "description": "Block name to delete"
            }
          },
          "required": [
            "device",
            "block"
          ]
        }
      },
      {
        "name": "tia_compile_device",
        "displayName": "Compile Device",
        "modelDescription": "Compile all software on a PLC device. Returns error/warning count and messages.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "device": {
              "type": "string",
              "description": "Device name"
            }
          },
          "required": [
            "device"
          ]
        }
      },
      {
        "name": "tia_compile_block",
        "displayName": "Compile Block",
        "modelDescription": "Compile a single block (faster than full device compilation)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "device": {
              "type": "string",
              "description": "Device name"
            },
            "block": {
              "type": "string",
              "description": "Block name"
            }
          },
          "required": [
            "device",
            "block"
          ]
        }
      },
      {
        "name": "tia_list_tag_tables",
        "displayName": "List Tag Tables",
        "modelDescription": "List all PLC tag tables for a device",
        "inputSchema": {
          "type": "object",
          "properties": {
            "device": {
              "type": "string",
              "description": "Device name"
            }
          },
          "required": [
            "device"
          ]
        }
      },
      {
        "name": "tia_list_tags",
        "displayName": "List Tags",
        "modelDescription": "List all tags in a specific tag table with names, data types, addresses and comments",
        "inputSchema": {
          "type": "object",
          "properties": {
            "device": {
              "type": "string",
              "description": "Device name"
            },
            "tagTable": {
              "type": "string",
              "description": "Tag table name"
            }
          },
          "required": [
            "device",
            "tagTable"
          ]
        }
      },
      {
        "name": "tia_create_tag",
        "displayName": "Create Tag",
        "modelDescription": "Create a new PLC tag in a tag table",
        "inputSchema": {
          "type": "object",
          "properties": {
            "device": {
              "type": "string",
              "description": "Device name"
            },
            "tagTable": {
              "type": "string",
              "description": "Tag table name"
            },
            "name": {
              "type": "string",
              "description": "Tag name"
            },
            "dataType": {
              "type": "string",
              "description": "Data type (Bool, Int, Real, etc.)"
            },
            "address": {
              "type": "string",
              "description": "Logical address (e.g. %I0.0, %Q0.0, %MW10)"
            },
            "comment": {
              "type": "string",
              "description": "Optional comment"
            }
          },
          "required": [
            "device",
            "tagTable",
            "name",
            "dataType",
            "address"
          ]
        }
      },
      {
        "name": "tia_list_udts",
        "displayName": "List UDTs",
        "modelDescription": "List all User Defined Types (UDTs) for a device",
        "inputSchema": {
          "type": "object",
          "properties": {
            "device": {
              "type": "string",
              "description": "Device name"
            }
          },
          "required": [
            "device"
          ]
        }
      },
      {
        "name": "tia_get_cross_references",
        "displayName": "Get Cross References",
        "modelDescription": "Get cross-references for a block — shows where it is used and what it references",
        "inputSchema": {
          "type": "object",
          "properties": {
            "device": {
              "type": "string",
              "description": "Device name"
            },
            "block": {
              "type": "string",
              "description": "Block name"
            }
          },
          "required": [
            "device",
            "block"
          ]
        }
      },
      {
        "name": "tia_download_to_plc",
        "displayName": "Download to PLC",
        "modelDescription": "Download the program to a PLC or PLCSim instance",
        "inputSchema": {
          "type": "object",
          "properties": {
            "device": {
              "type": "string",
              "description": "Device name"
            },
            "scope": {
              "type": "string",
              "enum": [
                "Software",
                "HardwareAndSoftware"
              ],
              "description": "Download scope (default: Software)"
            }
          },
          "required": [
            "device"
          ]
        }
      },
      {
        "name": "tia_go_online",
        "displayName": "Go Online",
        "modelDescription": "Establish online connection to a PLC",
        "inputSchema": {
          "type": "object",
          "properties": {
            "device": {
              "type": "string",
              "description": "Device name"
            }
          },
          "required": [
            "device"
          ]
        }
      },
      {
        "name": "tia_go_offline",
        "displayName": "Go Offline",
        "modelDescription": "Disconnect online connection from a PLC",
        "inputSchema": {
          "type": "object",
          "properties": {
            "device": {
              "type": "string",
              "description": "Device name"
            }
          },
          "required": [
            "device"
          ]
        }
      },
      {
        "name": "tia_plcsim_status",
        "displayName": "PLCSim Status",
        "modelDescription": "Get PLCSim Advanced simulation status — check if simulator is running and instances available",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "tia_plcsim_read_tag",
        "displayName": "PLCSim Read Tag",
        "modelDescription": "Read a tag value from PLCSim simulation",
        "inputSchema": {
          "type": "object",
          "properties": {
            "tagName": {
              "type": "string",
              "description": "Tag name to read (e.g. bStart, DB1.value)"
            }
          },
          "required": [
            "tagName"
          ]
        }
      },
      {
        "name": "tia_plcsim_write_tag",
        "displayName": "PLCSim Write Tag",
        "modelDescription": "Write a value to a tag in PLCSim simulation",
        "inputSchema": {
          "type": "object",
          "properties": {
            "tagName": {
              "type": "string",
              "description": "Tag name to write"
            },
            "value": {
              "type": "string",
              "description": "Value to write"
            }
          },
          "required": [
            "tagName",
            "value"
          ]
        }
      },
      {
        "name": "tia_run_tests",
        "displayName": "Run PLC Tests",
        "modelDescription": "Run PLC unit tests via PLCSim. Returns test results with pass/fail status for each test case.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "device": {
              "type": "string",
              "description": "Device name"
            }
          },
          "required": [
            "device"
          ]
        }
      },
      {
        "name": "tia_vcs_status",
        "displayName": "VCS Status",
        "modelDescription": "Get version control status — pending changes, last commit info",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "tia_vcs_commit",
        "displayName": "VCS Commit",
        "modelDescription": "Commit pending changes to version control",
        "inputSchema": {
          "type": "object",
          "properties": {
            "message": {
              "type": "string",
              "description": "Commit message"
            }
          },
          "required": [
            "message"
          ]
        }
      },
      {
        "name": "tia_vcs_diff",
        "displayName": "VCS Diff",
        "modelDescription": "Get diff of pending changes in version control",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "tia_pipeline_list",
        "displayName": "List Pipelines",
        "modelDescription": "List available CI/CD pipelines",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "tia_pipeline_run",
        "displayName": "Run Pipeline",
        "modelDescription": "Execute a CI/CD pipeline by name",
        "inputSchema": {
          "type": "object",
          "properties": {
            "pipeline": {
              "type": "string",
              "description": "Pipeline name"
            }
          },
          "required": [
            "pipeline"
          ]
        }
      },
      {
        "name": "tia_search_catalog",
        "displayName": "Search Hardware Catalog",
        "modelDescription": "Search the TIA Portal hardware catalog for modules, CPUs, I/O cards by keyword or order number",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query (e.g. '1511', 'DI 32', '6ES7')"
            }
          },
          "required": [
            "query"
          ]
        }
      },
      {
        "name": "tia_add_device",
        "displayName": "Add Device",
        "modelDescription": "Add a new device (PLC, HMI) to the project by order number",
        "inputSchema": {
          "type": "object",
          "properties": {
            "orderNumber": {
              "type": "string",
              "description": "Siemens order number (e.g. 6ES7 511-1AK02-0AB0)"
            },
            "name": {
              "type": "string",
              "description": "Optional device name"
            }
          },
          "required": [
            "orderNumber"
          ]
        }
      }
    ],
    "commands": [
      {
        "command": "tiaConnect.connect",
        "title": "%command.connect%",
        "category": "T-IA Connect",
        "icon": "$(plug)"
      },
      {
        "command": "tiaConnect.disconnect",
        "title": "%command.disconnect%",
        "category": "T-IA Connect",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "tiaConnect.refreshProject",
        "title": "%command.refreshProject%",
        "category": "T-IA Connect",
        "icon": "$(refresh)"
      },
      {
        "command": "tiaConnect.openBlock",
        "title": "%command.openBlock%",
        "category": "T-IA Connect",
        "icon": "$(go-to-file)"
      },
      {
        "command": "tiaConnect.compileDevice",
        "title": "%command.compileDevice%",
        "category": "T-IA Connect",
        "icon": "$(gear)"
      },
      {
        "command": "tiaConnect.compileBlock",
        "title": "%command.compileBlock%",
        "category": "T-IA Connect",
        "icon": "$(check)"
      },
      {
        "command": "tiaConnect.exportBlock",
        "title": "%command.exportBlock%",
        "category": "T-IA Connect",
        "icon": "$(desktop-download)"
      },
      {
        "command": "tiaConnect.vcsCommit",
        "title": "%command.vcsCommit%",
        "category": "T-IA Connect VCS",
        "icon": "$(check)"
      },
      {
        "command": "tiaConnect.vcsRefresh",
        "title": "%command.vcsRefresh%",
        "category": "T-IA Connect VCS",
        "icon": "$(refresh)"
      },
      {
        "command": "tiaConnect.vcsInit",
        "title": "%command.vcsInit%",
        "category": "T-IA Connect VCS",
        "icon": "$(repo)"
      },
      {
        "command": "tiaConnect.vcsPush",
        "title": "%command.vcsPush%",
        "category": "T-IA Connect VCS",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "tiaConnect.vcsPull",
        "title": "%command.vcsPull%",
        "category": "T-IA Connect VCS",
