{
  "Function Block": {
    "prefix": "fb",
    "body": [
      "FUNCTION_BLOCK \"${1:FB_Name}\"",
      "{ S7_Optimized_Access := 'TRUE' }",
      "VERSION : 0.1",
      "",
      "VAR_INPUT",
      "    ${2:bEnable} : Bool;",
      "END_VAR",
      "",
      "VAR_OUTPUT",
      "    ${3:bDone} : Bool;",
      "END_VAR",
      "",
      "VAR",
      "    ${4:// Static variables}",
      "END_VAR",
      "",
      "BEGIN",
      "    $0",
      "END_FUNCTION_BLOCK"
    ],
    "description": "SCL Function Block (FB)"
  },
  "Function": {
    "prefix": "fc",
    "body": [
      "FUNCTION \"${1:FC_Name}\" : ${2:Void}",
      "{ S7_Optimized_Access := 'TRUE' }",
      "VERSION : 0.1",
      "",
      "VAR_INPUT",
      "    ${3:iValue} : Int;",
      "END_VAR",
      "",
      "VAR_TEMP",
      "    ${4:// Temp variables}",
      "END_VAR",
      "",
      "BEGIN",
      "    $0",
      "END_FUNCTION"
    ],
    "description": "SCL Function (FC)"
  },
  "Organization Block": {
    "prefix": "ob",
    "body": [
      "ORGANIZATION_BLOCK \"${1:OB1}\"",
      "{ S7_Optimized_Access := 'TRUE' }",
      "VERSION : 0.1",
      "",
      "BEGIN",
      "    $0",
      "END_ORGANIZATION_BLOCK"
    ],
    "description": "SCL Organization Block (OB)"
  },
  "Data Block": {
    "prefix": "db",
    "body": [
      "DATA_BLOCK \"${1:DB_Name}\"",
      "{ S7_Optimized_Access := 'TRUE' }",
      "VERSION : 0.1",
      "NON_RETAIN",
      "",
      "VAR",
      "    ${2:bFlag} : Bool;",
      "    $0",
      "END_VAR",
      "",
      "BEGIN",
      "",
      "END_DATA_BLOCK"
    ],
    "description": "SCL Data Block (DB)"
  },
  "IF THEN": {
    "prefix": "if",
    "body": [
      "IF ${1:condition} THEN",
      "    $0",
      "END_IF;"
    ],
    "description": "IF...THEN...END_IF"
  },
  "IF THEN ELSE": {
    "prefix": "ife",
    "body": [
      "IF ${1:condition} THEN",
      "    $2",
      "ELSE",
      "    $0",
      "END_IF;"
    ],
    "description": "IF...THEN...ELSE...END_IF"
  },
  "FOR Loop": {
    "prefix": "for",
    "body": [
      "FOR #${1:i} := ${2:0} TO ${3:10} BY ${4:1} DO",
      "    $0",
      "END_FOR;"
    ],
    "description": "FOR loop"
  },
  "WHILE Loop": {
    "prefix": "while",
    "body": [
      "WHILE ${1:condition} DO",
      "    $0",
      "END_WHILE;"
    ],
    "description": "WHILE loop"
  },
  "CASE OF": {
    "prefix": "case",
    "body": [
      "CASE ${1:#iState} OF",
      "    0:",
      "        $2",
      "    1:",
      "        $3",
      "    ELSE",
      "        $0",
      "END_CASE;"
    ],
    "description": "CASE...OF statement"
  },
  "REPEAT UNTIL": {
    "prefix": "repeat",
    "body": [
      "REPEAT",
      "    $0",
      "UNTIL ${1:condition}",
      "END_REPEAT;"
    ],
    "description": "REPEAT...UNTIL loop"
  },
  "TON Timer": {
    "prefix": "ton",
    "body": [
      "#${1:tonTimer}(IN := ${2:#bStart},",
      "             PT := T#${3:1s},",
      "             Q => ${4:#bTimerDone},",
      "             ET => ${5:#tElapsed});"
    ],
    "description": "TON (On-Delay Timer) call"
  },
  "TOF Timer": {
    "prefix": "tof",
    "body": [
      "#${1:tofTimer}(IN := ${2:#bStart},",
      "             PT := T#${3:1s},",
      "             Q => ${4:#bTimerDone},",
      "             ET => ${5:#tElapsed});"
    ],
    "description": "TOF (Off-Delay Timer) call"
  },
  "R_TRIG": {
    "prefix": "rtrig",
    "body": [
      "#${1:rTrig}(CLK := ${2:#bSignal},",
      "          Q => ${3:#bRisingEdge});"
    ],
    "description": "R_TRIG (Rising Edge) call"
  },
  "FB Call": {
    "prefix": "call",
    "body": [
      "\"${1:FB_Instance}\"(${2:bEnable} := ${3:#bStart},",
      "                ${4:bDone} => ${5:#bResult});"
    ],
    "description": "Call a Function Block instance"
  },
  "REGION": {
    "prefix": "region",
    "body": [
      "REGION ${1:Description}",
      "    $0",
      "END_REGION"
    ],
    "description": "REGION block"
  }
}
